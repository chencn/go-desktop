<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="go-desktop.exe"
        Arguments=""
        InstallLocation="%LOCALAPPDATA%\Programs\go-desktop">
    </Installer>
    <PackageInformation
        PackageName="com.chencn.godesktop"
        PackageDisplayName="go-desktop"
        PublisherName="CN=chencn"
        PublisherDisplayName="chencn"
        Version="0.0.1.0"
        PackageDescription="Wails3 中文桌面工具">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="com.chencn.godesktop"
                Description="Wails3 中文桌面工具"
                DisplayName="go-desktop"
                ExecutableName="go-desktop.exe"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="zh-cn" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>go-desktop</DisplayName>
            <PublisherDisplayName>chencn</PublisherDisplayName>
            <Description>Wails3 中文桌面工具</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="go-desktop.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
