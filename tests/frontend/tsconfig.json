{
  "extends": "../../frontend/tsconfig.json",
  "compilerOptions": {
    "baseUrl": "../../frontend",
    "types": ["node"],
    "typeRoots": ["../../frontend/node_modules/@types"],
    "paths": {
      "@/*": ["./src/*"],
      "vitest": ["./node_modules/vitest/dist/index.d.ts"]
    }
  },
  "include": [
    "*.test.ts",
    "../../frontend/src/**/*.ts",
    "../../frontend/src/**/*.d.ts",
    "../../frontend/bindings/**/*.ts"
  ],
  "exclude": [
    "../../frontend/src/components/ui/**/*.vue"
  ]
}
