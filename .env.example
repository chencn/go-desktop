# 不配置 GO_DESKTOP_LICENSE_MODE 时授权关闭。
# 需要本地构建授权版时，复制本文件为 .env，并把 GO_DESKTOP_LICENSE_MODE 改为 required。
GO_DESKTOP_LICENSE_MODE=

# 公钥只用于客户端验签，可以公开；会通过构建参数打包进授权版客户端。
# 授权版示例：
# GO_DESKTOP_LICENSE_MODE=required
GO_DESKTOP_LICENSE_PUBLIC_KEY=

# 私钥只给本地授权码签发脚本读取，不会被打包进客户端；不要提交真实私钥。
# 本地签发示例：
# go run ./scripts/license_issue.go -device GD-7K3F-9P2X-MQ8C
GO_DESKTOP_LICENSE_PRIVATE_KEY=
